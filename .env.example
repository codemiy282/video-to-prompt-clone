# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored, so secrets are never committed.

# Required: Gemini API key used by the Next.js server-side API routes
# (image-to-prompt, storyboard, veo, kling, runway, seedance, ...).
# Note: the image-to-video dummy feature does NOT need this key.
GEMINI_API_KEY=

# Optional: Pexels API key for image-to-video.
# Nếu có key, image-to-video sẽ tìm video stock THẬT khớp với prompt qua Pexels
# (free tier ~200 req/giờ, 20k/tháng -> 0đ). Không có key thì tự dùng pool tĩnh.
# Lấy key miễn phí: https://www.pexels.com/api/
PEXELS_API_KEY=

# Optional: nhận feedback cộng đồng qua Discord (miễn phí).
# Nếu set, mọi feedback/feature-request/bug từ trang /feedback sẽ được đẩy vào
# kênh Discord này. Không set thì feedback vẫn nhận và ghi vào server logs.
# Tạo webhook: Discord → Server Settings → Integrations → Webhooks → New Webhook.
FEEDBACK_DISCORD_WEBHOOK=

# Optional: image-to-video dummy pool.
# - "false" (MẶC ĐỊNH): chỉ dùng nhóm host luôn truy cập được
#   (test-videos.co.uk / w3.org / MDN / w3schools / samplelib / filesamples) -> an toàn.
# - "true": thêm nhóm Google (chủ đề xe/sci-fi/city/people...). CHỈ set nếu mạng
#   bạn tới được Google Cloud Storage (bị chặn ở nhiều nơi -> 403).
DUMMY_INCLUDE_GOOGLE=false
