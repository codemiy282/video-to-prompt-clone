# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored, so secrets are never committed.

# Required: Gemini API key used by the Next.js server-side API routes
# (image-to-prompt, storyboard, veo, kling, runway, seedance, ...).
# Note: the image-to-video dummy feature does NOT need this key.
GEMINI_API_KEY=

# Optional: image-to-video dummy pool.
# - "true" (mặc định): bao gồm cả nhóm Google (chủ đề xe/sci-fi/city/people...).
#   Chỉ hoạt động nếu VPS của bạn tới được Google Cloud Storage.
# - "false": chỉ dùng nhóm host luôn truy cập được (an toàn tuyệt đối).
DUMMY_INCLUDE_GOOGLE=true
