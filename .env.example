# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored, so secrets are never committed.

# Required: Gemini API key used by the Next.js server-side API routes
# (image-to-prompt, storyboard, veo, kling, runway, seedance, ...).
GEMINI_API_KEY=

# URL of the LTX-Video Python backend.
# - On the VPS (docker compose): http://ltx-backend:8000
# - Local dev (backend running on host): http://localhost:8000
# Leave empty if you don't run the GPU backend.
LTX_VIDEO_BACKEND_URL=http://ltx-backend:8000
